# ──────────────────────────────────────────────
#  Environment & secrets (NEVER commit these)
# ──────────────────────────────────────────────
.env
.env.*
!.env.example
*.key
*.pem

# ──────────────────────────────────────────────
#  IDE / editor
# ──────────────────────────────────────────────
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.DS_Store
Thumbs.db

# ──────────────────────────────────────────────
#  Logs
# ──────────────────────────────────────────────
*.log
npm-debug.log*

# ──────────────────────────────────────────────
#  Node / Frontend build
# ──────────────────────────────────────────────
frontend/node_modules/
frontend/dist/

# ──────────────────────────────────────────────
#  Laravel backend
# ──────────────────────────────────────────────
laravel-backend/vendor/
laravel-backend/node_modules/
laravel-backend/storage/*.key
laravel-backend/.phpunit.result.cache
laravel-backend/.phpunit.cache/

# ──────────────────────────────────────────────
#  Legacy PHP configs with credentials
# ──────────────────────────────────────────────
backend/config.local.php
backend/config.production.php
dashboard/config.php

# ──────────────────────────────────────────────
#  Deployment docs (keep private)
# ──────────────────────────────────────────────
DEPLOY.md

# ──────────────────────────────────────────────
#  OS / misc
# ──────────────────────────────────────────────
*.bak
*.tmp
*.swp
