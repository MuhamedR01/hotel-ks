# ──────────────────────────────────────────────────────────────
#  Hotel KS — Docker Compose environment (copy to .env)
# ──────────────────────────────────────────────────────────────
#  Copy this file to .env and set the values before running:
#    cp .env.example .env
# ──────────────────────────────────────────────────────────────

# Required: Database (MySQL container uses these to create DB and user)
DB_DATABASE=hotel_ks
DB_USERNAME=hotel_ks
DB_PASSWORD=change_me_secure_password

# Required: Laravel
APP_KEY=

# Required: Admin default password for dashboard
ADMIN_DEFAULT_PASSWORD=change_me_admin_password

# Optional: URLs (defaults used if not set)
# API_URL=https://api.hotel-ks.com
# DASHBOARD_URL=https://dashboard.hotel-ks.com
# FRONTEND_URL=https://hotel-ks.com
# SANCTUM_STATEFUL_DOMAINS=hotel-ks.com,dashboard.hotel-ks.com
